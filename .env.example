# LoopFlow — Variables de Entorno
# Copia este archivo como .env y completa con tus credenciales reales de Clever Cloud.
# NUNCA subas el archivo .env al repositorio. Ya está en .gitignore.

# ============================================================
# BASE DE DATOS — Clever Cloud MySQL
# Obtén estos valores desde el panel de Clever Cloud:
# Dashboard → Tu app → Service dependencies → MySQL → Environment variables
# ============================================================
DB_URL=jdbc:mysql://your-host.services.clever-cloud.com:3306/your_database_name?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=your_clever_cloud_user
DB_PASSWORD=your_clever_cloud_password

# ============================================================
# SERVIDOR — Configuración de Jetty
# ============================================================
# Puerto donde correrá la API + frontend (default: 8080)
# Render.com usa la variable PORT automáticamente.
PORT=9000

# ============================================================
# CORS — Orígenes permitidos
# Para desarrollo local: *
# Para producción: https://tu-app.netlify.app
# Múltiples orígenes separados por coma: https://app1.com,https://app2.com
# ============================================================
ALLOWED_ORIGINS=*
